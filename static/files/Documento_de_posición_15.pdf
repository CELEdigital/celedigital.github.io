s_it":true,"ts_va_i":true,"ts_bd_i":true,"ts_fs":11.0,"ts_it_i":true,"ts_sc_i":true,"ts_fgc2_i":true,"ts_st_i":true,"ts_fs_i":true}},{"ty":"as","st":"text","si":7476,"ei":7482,"sm":{"ts_un":true,"ts_un_i":false,"ts_it_i":true,"ts_fgc2":{"hclr_color":"#1155cc","clr_type":0},"ts_st_i":true,"ts_fs_i":true,"ts_ff_i":true,"ts_bgc2_i":true,"ts_it":true,"ts_va_i":true,"ts_bd_i":true,"ts_fs":11.0,"ts_sc_i":true,"ts_fgc2_i":false}},{"ty":"as","st":"text","si":7483,"ei":7487,"sm":{"ts_un":true,"ts_un_i":true,"ts_it_i":true,"ts_fgc2":{"hclr_color":"#1155cc","clr_type":0},"ts_st_i":true,"ts_fs_i":true,"ts_ff_i":true,"ts_bgc2_i":true,"ts_it":true,"ts_va_i":true,"ts_bd_i":true,"ts_fs":11.0,"ts_sc_i":true,"ts_fgc2_i":true}},{"ty":"as","st":"text","si":7488,"ei":7494,"sm":{"ts_un":true,"ts_un_i":false,"ts_it_i":true,"ts_fgc2":{"hclr_color":"#1155cc","clr_type":0},"ts_st_i":true,"ts_fs_i":true,"ts_ff_i":true,"ts_bgc2_i":true,"ts_it":true,"ts_va_i":true,"ts_bd_i":true,"ts_fs":11.0,"ts_sc_i":true,"ts_fgc2_i":false}},{"ty":"as","st":"text","si":7495,"ei":7840,"sm":{"ts_un":true,"ts_un_i":true,"ts_it_i":true,"ts_fgc2":{"hclr_color":"#1155cc","clr_type":0},"ts_st_i":true,"ts_fs_i":true,"ts_ff_i":true,"ts_bgc2_i":true,"ts_it":true,"ts_va_i":true,"ts_bd_i":true,"ts_fs":11.0,"ts_sc_i":true,"ts_fgc2_i":true}},{"ty":"as","st":"text","si":7841,"ei":7855,"sm":{"ts_bd_i":false,"ts_fs":11.0,"ts_bd":true,"ts_fs_i":false}},{"ty":"as","st":"text","si":7856,"ei":7973,"sm":{"ts_fs":11.0,"ts_fs_i":false}},{"ty":"as","st":"text","si":7974,"ei":8564,"sm":{"ts_ff_i":true,"ts_un_i":true,"ts_bgc2_i":true,"ts_it":true,"ts_va_i":true,"ts_bd_i":true,"ts_fs":11.0,"ts_it_i":false,"ts_sc_i":true,"ts_fgc2_i":true,"ts_st_i":true,"ts_fs_i":true}},{"ty":"as","st":"text","si":8565,"ei":8579,"sm":{"ts_bd_i":false,"ts_fs":11.0,"ts_bd":true,"ts_fs_i":false}},{"ty":"as","st":"text","si":8580,"ei":8688,"sm":{"ts_fs":11.0,"ts_fs_i":false}},{"ty":"as","st":"text","si":8689,"ei":8705,"sm":{"ts_ff_i":true,"ts_un_i":true,"ts_bg